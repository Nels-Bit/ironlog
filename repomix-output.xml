                        <div className={cn("transition-transform duration-300 text-zinc-500", isCollapsed ? "-rotate-90" : "rotate-0")}>
                            <ChevronDown size={20} />
                        </div>
                        <div>
                            <h3 className="text-white font-bold text-lg flex items-center gap-2 truncate">
