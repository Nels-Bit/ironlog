import { Link, useLocation, useNavigate } from 'react-router-dom';
import { LayoutDashboard, Calendar, User, Dumbbell, Plus, ChevronRight } from 'lucide-react';
import { cn } from '../lib/utils';
import { useWorkout } from '../context/WorkoutContext'; // Use Context

export const Navbar = () => {
  const location = useLocation();
  const navigate = useNavigate();
  const path = location.pathname;
  
  // Get active workout status
  const { isActive, workout } = useWorkout();

  const handleWorkoutClick = (e: React.MouseEvent) => {
    e.preventDefault();
    if (path === '/workout' || path.startsWith('/history/')) {
      window.dispatchEvent(new CustomEvent('open-exercise-selector'));
    } else {
      navigate('/workout');
    }
  };

  return (
    <>
      {/* MOBILE BOTTOM NAV */}
      <nav className="md:hidden fixed bottom-0 left-0 right-0 h-20 bg-iron-950/90 backdrop-blur-lg border-t border-white/10 z-[100] pb-safe">
        <div className="grid grid-cols-5 h-full items-center">
          <Link to="/" className="flex flex-col items-center justify-center text-zinc-500 hover:text-white transition-colors gap-1"><LayoutDashboard size={22} className={cn(path === '/' && "text-brand-orange")} /></Link>
          <Link to="/history" className="flex flex-col items-center justify-center text-zinc-500 hover:text-white transition-colors gap-1"><Calendar size={22} className={cn(path === '/history' && "text-brand-orange")} /></Link>

          <div className="flex justify-center -mt-6">
            <button onClick={handleWorkoutClick} className={cn("w-14 h-14 rounded-full flex items-center justify-center shadow-lg shadow-brand-orange/20 transition-all active:scale-95 border-4 border-black", (path === '/workout' || path.startsWith('/history/')) ? "bg-white text-brand-orange" : "bg-brand-orange text-white")}>
              {(path === '/workout' || path.startsWith('/history/')) ? <Plus size={28} strokeWidth={3} /> : <Dumbbell size={24} fill="currentColor" />}
            </button>
          </div>

          <Link to="/profile" className="col-start-4 flex flex-col items-center justify-center text-zinc-500 hover:text-white transition-colors gap-1"><User size={22} className={cn(path === '/profile' && "text-brand-orange")} /></Link>
          <div className="col-start-5" /> 
        </div>
      </nav>

      {/* DESKTOP SIDEBAR */}
      <nav className="hidden md:flex fixed left-0 top-0 bottom-0 w-64 bg-iron-950 border-r border-white/10 flex-col p-6 z-50">
        <div className="flex items-center gap-3 mb-10 px-2">
          <div className="w-10 h-10 bg-brand-orange rounded-xl flex items-center justify-center"><Dumbbell className="text-white" size={20} /></div>
          <span className="font-black italic text-2xl text-white tracking-tighter">IRONLOG</span>
        </div>

        <div className="space-y-2">
          <NavItem to="/" icon={<LayoutDashboard size={20} />} label="Dashboard" active={path === '/'} />
          <NavItem to="/workout" icon={<Dumbbell size={20} />} label={isActive ? "Current Workout" : "Start Workout"} active={path === '/workout'} />
          <NavItem to="/history" icon={<Calendar size={20} />} label="History" active={path === '/history'} />
          <NavItem to="/profile" icon={<User size={20} />} label="Profile" active={path === '/profile'} />
        </div>

        {/* DESKTOP "ADD EXERCISE" BUTTON (Only shows if active and on workout page) */}
        {(path === '/workout' || path.startsWith('/history/')) && (
           <div className="mt-8 animate-in fade-in">
              <button 
                onClick={() => window.dispatchEvent(new CustomEvent('open-exercise-selector'))}
                className="w-full flex items-center justify-center gap-2 bg-white text-brand-orange font-bold py-3 rounded-xl hover:bg-zinc-100 transition-colors"
              >
                <Plus size={20} strokeWidth={3} /> Add Exercise
              </button>
           </div>
        )}

        {/* ACTIVE WORKOUT INDICATOR (If navigating elsewhere) */}
        {isActive && path !== '/workout' && (
           <div className="mt-auto pt-6 border-t border-white/10">
              <Link to="/workout" className="block bg-brand-orange/10 border border-brand-orange/20 rounded-xl p-4 hover:bg-brand-orange/20 transition-colors group">
                 <div className="flex items-center justify-between mb-1">
                    <span className="text-brand-orange text-xs font-bold uppercase tracking-wider">Active Session</span>
                    <div className="w-2 h-2 rounded-full bg-brand-orange animate-pulse" />
                 </div>
                 <div className="flex items-center justify-between text-white font-bold">
                    <span>{workout?.name}</span>
                    <ChevronRight size={16} className="group-hover:translate-x-1 transition-transform"/>
                 </div>
              </Link>
           </div>
        )}
      </nav>
    </>
  );
};

const NavItem = ({ to, icon, label, active }: any) => (
  <Link to={to} className={cn("flex items-center gap-3 px-4 py-3 rounded-xl transition-colors font-medium", active ? "bg-brand-orange text-white" : "text-zinc-500 hover:text-white hover:bg-white/5")}>
    {icon} <span>{label}</span>
  </Link>
);
