import { supabase } from '../lib/supabase';
import type { WorkoutSession, WorkoutExercise } from '../types';

export const workoutService = {
  // 1. Save a completed workout to Cloud
  saveWorkout: async (workout: WorkoutSession): Promise<void> => {
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) throw new Error("User not authenticated");

    const volume = workoutService.calculateVolume(workout);
    const finalWorkout = { ...workout, volumeLoad: volume, endTime: Date.now() };

    const { error } = await supabase
      .from('workouts')
      .insert({
        user_id: user.id,
        data: finalWorkout
      });

    if (error) {
      console.error('Error saving workout:', error);
      alert('Failed to save workout to cloud.');
    }
  },

  // 2. Get all past workouts
  getHistory: async (): Promise<WorkoutSession[]> => {
    const { data, error } = await supabase
      .from('workouts')
      .select('id, data, created_at') // Get ID to ensure we map it correctly
      .order('created_at', { ascending: false });

    if (error) {
      console.error('Error fetching history:', error);
      return [];
    }

    // Map the Supabase row ID to the workout object ID just in case
    return data.map((row: any) => ({
      ...row.data,
      id: row.id // Ensure the ID matches the database row ID
    })) as WorkoutSession[];
  },

  // 3. Get a single workout by ID (For Editing)
  getWorkoutById: async (id: string): Promise<WorkoutSession | null> => {
    const { data, error } = await supabase
      .from('workouts')
      .select('data')
      .eq('id', id)
      .single();

    if (error) return null;
    return data.data as WorkoutSession;
  },

  // 4. Update an existing workout
  updateWorkout: async (id: string, updatedWorkout: WorkoutSession): Promise<void> => {
    const { error } = await supabase
      .from('workouts')
      .update({
        data: updatedWorkout
      })
      .eq('id', id);

    if (error) throw error;
  },
  
  // 5. Delete workout
  deleteWorkout: async (id: string): Promise<void> => {
    const { error } = await supabase
      .from('workouts')
      .delete()
      .eq('id', id);
      
    if (error) throw error;
  },

  // 6. Calculate Volume (Helper)
  calculateVolume: (workout: WorkoutSession): number => {
    let total = 0;
    workout.exercises.forEach(ex => {
      ex.sets.forEach(set => {
        if (set.isCompleted && set.weight) {
          // Handle Unilateral Volume
          if (set.repsLeft && set.repsRight) {
             total += set.weight * (set.repsLeft + set.repsRight);
          } 
          // Handle Standard Volume
          else if (set.reps) {
            total += set.weight * set.reps;
          }
        }
      });
    });
    return total;
  },

  // 7. Get Last Log (Ghost Data)
  getLastLog: async (exerciseId: string): Promise<WorkoutExercise | undefined> => {
    // Optimization: In a real app, you'd want a specific RPC or query for this.
    // For MVP, fetching history is okay since Supabase caches well.
    const history = await workoutService.getHistory();
    for (const workout of history) {
      const found = workout.exercises.find(e => e.exerciseId === exerciseId);
      if (found) return found;
    }
    return undefined;
  }
};
